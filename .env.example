# ============================================================
# X (Twitter) Affiliate Bot - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- X (Twitter) API Credentials ---
# Obtain from: https://developer.twitter.com/en/portal/dashboard
# Required access level: Free (v2 write + v1.1 media upload)
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# --- Google Gemini API ---
# Obtain from: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# --- Hugging Face API ---
# Obtain from: https://huggingface.co/settings/tokens
# Free tier: rate-limited but sufficient for 3 posts/day
HF_API_TOKEN=your_huggingface_token_here

# --- Affiliate Settings ---
# Rakuten affiliate tag (後で手動で差し替え可)
RAKUTEN_AFFILIATE_ID=your_rakuten_id_here

# --- Bot Behavior ---
# Number of posts per run (keep low to stay within free tier limits)
POSTS_PER_RUN=1
