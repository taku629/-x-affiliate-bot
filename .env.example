# ============================================================
# X Affiliate Bot - Environment Variables
# ============================================================
# cp .env.example .env してから値を入力してください。
# .env は絶対に git に commit しないこと（.gitignore 確認済み）。
#
# 【必須】起動時にチェックされ、未設定だとボットが即終了します
#   ANTHROPIC_API_KEY, X_API_KEY, X_API_SECRET,
#   X_ACCESS_TOKEN, X_ACCESS_TOKEN_SECRET
# ============================================================

# --- [必須] Anthropic Claude API ---
# 取得: https://console.anthropic.com/
# 用途: 投稿文の生成（claude-haiku-4-5 使用）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- [必須] X (Twitter) API Credentials ---
# 取得: https://developer.twitter.com/en/portal/dashboard
# 必要な権限: Free プラン + Read & Write
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# --- [任意] X Bearer Token ---
# なくても投稿は動作するが、あると API 初期化が安定する
X_BEARER_TOKEN=your_bearer_token_here

# --- [任意] Hugging Face API ---
# 取得: https://huggingface.co/settings/tokens
# --no-image で実行する場合は不要
HF_API_TOKEN=your_huggingface_token_here

# --- [任意] Affiliate Settings ---
# RAKUTEN_AFFILIATE_ID: 楽天アフィリエイト管理画面で確認（トラッキングIDの付与に使用）
RAKUTEN_AFFILIATE_ID=your_rakuten_id_here

# AFFILIATE_ASP: 使用するASP（rakuten / amazon）
# amazon の場合は src/affiliate.py の AFFILIATE_LINKS_AMAZON の tag= を差し替えること
AFFILIATE_ASP=rakuten

# ============================================================
# Bot 動作設定
# ============================================================

# 1回の実行あたりの投稿件数（X Free枠: 50件/24h）
POSTS_PER_RUN=1

# 1日（24時間）の最大投稿件数。この件数に達すると以降の投稿をスキップする。
# 初回本番は小さめに設定することを推奨（X Free枠は50件/24h）
DAILY_MAX_POSTS=5

# アフィリエイト投稿の割合（0.0〜1.0）
# 初回本番推奨: 0.0（全件通常投稿で動作確認してから上げる）
# 安定後推奨:   0.1〜0.2（全投稿の10〜20%をアフィリ投稿に）
AFFILIATE_RATIO=0.0

# 許可カテゴリ（カンマ区切り）。空にすると全カテゴリ許可。
# 投稿本数を最大化したい場合は空のまま推奨（日本のトレンドは tech 以外が多い）。
# 絞り込む場合の例: ALLOWED_CATEGORIES=tech,sports,entertainment
ALLOWED_CATEGORIES=
